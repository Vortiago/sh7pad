{
  "name": "sh7pad",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Browser-based viewer, creator, and editor for .sh7 decorative-stitch files.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vortiago/sh7pad.git"
  },
  "homepage": "https://vortiago.github.io/sh7pad/",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0",
    "axe-core": "^4.12.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
